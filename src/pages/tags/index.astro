---
import PostPreview from '@/components/custom/PostPreview.astro'
import { getBlogCollection, getUniqueTagsWithCount, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const collections = sortMDByDate(await getBlogCollection())
const tags = getUniqueTagsWithCount(collections)
---

<PageLayout title='标签' desc='按标签浏览所有文章'>
  <p class='mb-6 text-sm text-muted-foreground'>共 {tags.length} 个标签</p>

  <div class='mb-8 flex flex-wrap gap-2'>
    {
      tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class='ai-card-hover inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm transition-all'
        >
          <span class='font-medium'>{tag}</span>
          <span class='rounded-full bg-muted px-1.5 py-0.5 text-xs text-muted-foreground'>
            {count}
          </span>
        </a>
      ))
    }
  </div>

  <div class='mt-6'>
    <Button title='← 返回首页' href='/' variant='back' />
  </div>
</PageLayout>
