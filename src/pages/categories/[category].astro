---
import type { GetStaticPaths } from 'astro'
import type { CollectionEntry } from 'astro:content'

import PostPreview from '@/components/custom/PostPreview.astro'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export const getStaticPaths = (async () => {
  const collections = await getBlogCollection()
  const categories = new Set<string>()
  for (const post of collections) {
    for (const c of post.data.categories ?? []) categories.add(c)
  }
  return Array.from(categories).map((category) => ({ params: { category } }))
}) satisfies GetStaticPaths

const { category } = Astro.params
const collections = sortMDByDate(await getBlogCollection())
const posts = collections.filter((p) => (p.data.categories ?? []).includes(category))

const categoryMeta: Record<string, { label: string; desc: string; color: string; emoji: string }> = {
  tutorials: { label: 'AI 教程', desc: '从 LLM 入门到 RAG、Agent 实战的进阶之路', color: '239 84% 67%', emoji: '📘' },
  market: { label: '市场分析', desc: '大模型厂商竞争格局、价格趋势与商业洞察', color: '188 95% 43%', emoji: '📊' },
  majors: { label: '高校专业', desc: '国内 AI 强校课程、师资与就业去向', color: '271 91% 65%', emoji: '🎓' },
  events: { label: '赛事活动', desc: 'Kaggle、NeurIPS 等顶赛清单与报名截止', color: '322 81% 60%', emoji: '🏆' },
  hackathons: { label: '黑客松', desc: '高质量 AI 黑客松实时推荐', color: '38 92% 50%', emoji: '⚡' },
  'cloud-deals': { label: '云厂商优惠', desc: '阿里云、腾讯云、华为云、火山引擎大模型 API 优惠', color: '160 84% 39%', emoji: '☁️' },
  't-agent': { label: 'T-agent', desc: '我正在做的多智能体协作框架', color: '262 83% 58%', emoji: '🤖' }
}

const meta = categoryMeta[category] ?? { label: category, desc: '', color: '239 84% 67%', emoji: '📚' }
const pageTitle = meta.label
const pageDesc = meta.desc || `AI 探索者「${pageTitle}」分类下的所有文章。`
---

<PageLayout meta={{ title: pageTitle, description: pageDesc }}>
  <main class='mt-6 w-full max-w-5xl px-4 lg:mt-10'>
    {/* Breadcrumb */}
    <nav class='mb-4 flex items-center gap-1 text-sm text-muted-foreground'>
      <a href='/' class='hover:text-primary'>首页</a>
      <span>/</span>
      <span>分类</span>
      <span>/</span>
      <span class='text-foreground'>{pageTitle}</span>
    </nav>

    {/* Header */}
    <header
      class='animate-ai mb-8 rounded-2xl border p-6 sm:p-8'
      style={`background: linear-gradient(135deg, hsl(${meta.color} / 0.08), transparent);
              border-color: hsl(${meta.color} / 0.2);`}
    >
      <div class='flex items-start gap-4'>
        <span class='text-4xl sm:text-5xl'>{meta.emoji}</span>
        <div class='flex-1'>
          <h1
            class='ai-hero-title !text-3xl sm:!text-4xl'
            style={`background: linear-gradient(135deg, hsl(${meta.color}), hsl(${meta.color} / 0.6));
                    -webkit-background-clip: text; background-clip: text;
                    -webkit-text-fill-color: transparent; color: transparent;`}
          >
            {pageTitle}
          </h1>
          <p class='mt-2 text-sm text-muted-foreground sm:text-base'>{pageDesc}</p>
          <p class='mt-3 inline-flex items-center gap-1.5 text-xs text-muted-foreground'>
            <Icon name='hash' class='size-3.5' />
            共 {posts.length} 篇文章
          </p>
        </div>
      </div>
    </header>

    {/* Posts list */}
    <div class='grid gap-8 sm:grid-cols-[3fr_1fr]'>
      <section class='animate-ai' style='animation-delay: 150ms;'>
        {
          posts.length === 0 ? (
            <div class='rounded-xl border border-dashed p-12 text-center text-muted-foreground'>
              <p class='mb-2 text-2xl'>📭</p>
              <p>该分类下暂无文章。</p>
            </div>
          ) : (
            <ul class='flex flex-col gap-3'>
              {posts.map((post, i) => (
                <li
                  class='animate-ai'
                  style={`animation-delay: ${150 + i * 60}ms;`}
                >
                  <PostPreview post={post} detailed />
                </li>
              ))}
            </ul>
          )
        }
      </section>

      {/* Sidebar: 其他分类 */}
      <aside class='animate-ai' style='animation-delay: 250ms;'>
        <h3 class='mb-3 flex items-center gap-1.5 text-sm font-semibold'>
          <Icon name='folder' class='size-4' />
          其他分类
        </h3>
        <div class='flex flex-col gap-2'>
          {
            Object.entries(categoryMeta)
              .filter(([slug]) => slug !== category)
              .map(([slug, m]) => (
                <a
                  href={`/categories/${slug}`}
                  class='ai-category-card !p-3'
                  style={`--card-color: ${m.color};`}
                >
                  <span class='flex items-center gap-2'>
                    <span>{m.emoji}</span>
                    <span class='ai-card-name !text-sm'>{m.label}</span>
                  </span>
                </a>
              ))
          }
        </div>
      </aside>
    </div>

    <div class='mt-10'>
      <Button title='← 返回首页' href='/' variant='back' />
    </div>
  </main>
</PageLayout>
