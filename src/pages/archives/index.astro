---
import PostPreview from '@/components/custom/PostPreview.astro'
import { getBlogCollection, groupCollectionsByYear, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const collections = sortMDByDate(await getBlogCollection())
const collectionsByYear = groupCollectionsByYear(collections)
const desc = '按年份查看所有文章'
---

<PageLayout title='时间线归档' {desc}>
  <p class='mb-6 text-sm text-muted-foreground'>共 {collections.length} 篇文章</p>

  {
    collectionsByYear.map(([year, posts], yi) => (
      <div class='animate-ai mb-8' style={`animation-delay: ${yi * 120}ms;`}>
        <div class='relative flex items-center gap-3'>
          <span class='ai-gradient-text text-2xl font-bold'>{year}</span>
          <span class='text-xs text-muted-foreground'>({posts.length} 篇)</span>
          <div class='h-px flex-1 bg-border' />
        </div>
        <div class='relative ms-4 mt-4 flex flex-col gap-2 border-s-2 border-border ps-6'>
          {posts.map((post, i) => (
            <div class='animate-ai relative' style={`animation-delay: ${yi * 120 + i * 50}ms;`}>
              <span class='absolute -left-[29px] top-3 h-3 w-3 rounded-full border-2 border-primary bg-background' />
              <PostPreview post={post} class='border-0 bg-transparent py-2' />
            </div>
          ))}
        </div>
      </div>
    ))
  }

  <div class='mt-6'>
    <Button title='← 返回首页' href='/' variant='back' />
  </div>
</PageLayout>
