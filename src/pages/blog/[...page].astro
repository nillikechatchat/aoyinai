---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import PostPreview from '@/components/custom/PostPreview.astro'
import { getBlogCollection, getUniqueTagsWithCount, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const collections = sortMDByDate(await getBlogCollection())
  const uniqueTags = getUniqueTagsWithCount(collections).map(([tag]) => tag)
  const collectionsCount = collections.length
  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  collectionsCount: number
}

const { page, uniqueTags, collectionsCount } = Astro.props

const categoryCards = [
  { slug: 'tutorials', label: 'AI 教程', emoji: '📘', color: '239 84% 67%' },
  { slug: 'market', label: '市场分析', emoji: '📊', color: '188 95% 43%' },
  { slug: 'majors', label: '高校专业', emoji: '🎓', color: '271 91% 65%' },
  { slug: 'events', label: '赛事活动', emoji: '🏆', color: '322 81% 60%' },
  { slug: 'hackathons', label: '黑客松', emoji: '⚡', color: '38 92% 50%' },
  { slug: 'cloud-deals', label: '云厂商', emoji: '☁️', color: '160 84% 39%' },
  { slug: 't-agent', label: 'T-agent', emoji: '🤖', color: '262 83% 58%' }
]

const meta = {
  description: 'AI 探索者 - 全部文章',
  title: '全部文章'
}

const paginationProps = {
  ...(page.url.prev && { prevUrl: { text: '← 上一页', url: page.url.prev } }),
  ...(page.url.next && { nextUrl: { text: '下一页 →', url: page.url.next } })
}
---

<PageLayout {meta}>
  <main class='mt-6 w-full max-w-5xl px-4 lg:mt-10'>
    {/* Breadcrumb */}
    <nav class='mb-4 flex items-center gap-1 text-sm text-muted-foreground'>
      <a href='/' class='hover:text-primary'>首页</a>
      <span>/</span>
      <span class='text-foreground'>全部文章</span>
    </nav>

    <header class='animate-ai mb-8'>
      <h1 class='ai-hero-title !text-3xl sm:!text-4xl'>全部文章</h1>
      <p class='mt-2 text-sm text-muted-foreground'>共 {collectionsCount} 篇，持续更新中</p>
    </header>

    {/* 分类快筛 */}
    <div class='animate-ai mb-8 flex flex-wrap gap-2' style='animation-delay: 100ms;'>
      {
        categoryCards.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            class='inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-xs font-medium transition-all hover:scale-105'
            style={`border-color: hsl(${c.color} / 0.3); color: hsl(${c.color} / 1); background: hsl(${c.color} / 0.06);`}
          >
            <span>{c.emoji}</span>
            {c.label}
          </a>
        ))
      }
    </div>

    {
      page.data.length === 0 ? (
        <div class='rounded-xl border border-dashed p-12 text-center text-muted-foreground'>
          <p class='mb-2 text-2xl'>📭</p>
          <p>暂无文章</p>
        </div>
      ) : (
        <div class='grid gap-y-10 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='文章列表' class='animate-ai' style='animation-delay: 200ms;'>
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                第 {page.currentPage} 页 · 显示 {page.data.length} / {collectionsCount} 篇
              </span>
              <a href='/archives' class='text-muted-foreground hover:text-primary' data-astro-prefetch>
                按年份查看 →
              </a>
            </div>
            <ul class='flex flex-col gap-y-3'>
              {page.data.map((post, i) => (
                <li class='animate-ai' style={`animation-delay: ${200 + i * 80}ms;`}>
                  <PostPreview {post} detailed />
                </li>
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          {/* Sidebar: 标签 */}
          {!!uniqueTags.length && (
            <aside class='animate-ai' style='animation-delay: 300ms;'>
              <h2 class='mb-4 flex items-center gap-1.5 text-sm font-semibold'>
                <Icon name='tag-2' class='size-4' />
                标签
              </h2>
              <ul class='flex flex-wrap gap-2'>
                {uniqueTags.slice(0, 50).map((tag) => (
                  <li>
                    <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                  </li>
                ))}
              </ul>
              <span class='mt-4 block text-end'>
                <a href='/tags' class='text-xs text-muted-foreground hover:text-primary' data-astro-prefetch>
                  查看全部标签 →
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
