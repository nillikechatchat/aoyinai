---
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  title: '404 - 页面不存在',
  description: '你访问的页面不存在'
}
---

<PageLayout {meta}>
  <main class='flex min-h-[60vh] flex-col items-center justify-center gap-6 text-center'>
    <div class='ai-hero-title !text-8xl'>404</div>
    <p class='text-lg text-muted-foreground'>页面不存在或已被移除</p>
    <a href='/' class='ai-btn-gradient'>← 返回首页</a>
  </main>
</PageLayout>
