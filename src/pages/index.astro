---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import PostPreview from '@/components/custom/PostPreview.astro'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

const MAX_POSTS = 8
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{svg,png,jpg,jpeg,webp,avif}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{svg,png,jpg,jpeg,webp,avif}"`
  )

const categoryCards = [
  { name: 'AI 教程', slug: 'tutorials', desc: '从 LLM 入门到 RAG、Agent 实战', color: '239 84% 67%', emoji: '📘' },
  { name: '市场分析', slug: 'market', desc: '大模型厂商竞争格局与价格趋势', color: '188 95% 43%', emoji: '📊' },
  { name: '高校专业', slug: 'majors', desc: '国内 AI 强校课程与就业去向', color: '271 91% 65%', emoji: '🎓' },
  { name: '赛事活动', slug: 'events', desc: 'Kaggle、NeurIPS 等顶赛清单', color: '322 81% 60%', emoji: '🏆' },
  { name: '黑客松', slug: 'hackathons', desc: '高质量 AI 黑客松实时推荐', color: '38 92% 50%', emoji: '⚡' },
  { name: '云厂商优惠', slug: 'cloud-deals', desc: '主流云厂商大模型 API 优惠', color: '160 84% 39%', emoji: '☁️' },
  { name: 'T-agent', slug: 't-agent', desc: '我正在做的多智能体协作框架', color: '262 83% 58%', emoji: '🤖' }
]

const stats = [
  { label: '主题分类', value: '7+' },
  { label: '精选文章', value: allPosts.length.toString() },
  { label: '持续更新', value: '100%' },
  { label: '实战导向', value: 'AI' }
]
---

<PageLayout meta={{ title: 'AI 探索者' }} highlightColor='#6366f1'>
  <main class='flex w-full flex-col items-center'>
    {/* ==================== Hero ==================== */}
    <section class='animate-ai w-full max-w-3xl px-4 pt-8 pb-12 text-center sm:pt-16 sm:pb-20'>
      <div class='mb-6 flex justify-center' style='animation-delay: 50ms;'>
        <a href='/about' class='ai-avatar-glow inline-block'>
          <Image
            src={images[imagePath]()}
            alt={config.logo.alt || 'AI 探索者'}
            class='h-24 w-24 rounded-full border-2 border-white sm:h-28 sm:w-28 dark:border-zinc-900'
            loading='eager'
            fetchpriority='high'
          />
        </a>
      </div>

      <h1 class='ai-hero-title mb-4' style='animation-delay: 100ms;'>
        {config.title}
      </h1>

      <p
        class='mx-auto mb-6 max-w-xl text-base text-muted-foreground sm:text-lg'
        style='animation-delay: 200ms;'
      >
        聚焦人工智能的中文博客 — <span class='ai-gradient-text font-semibold'>7 大主题</span>、<span
          class='ai-gradient-text font-semibold'>动效拉满</span
        >、<span class='ai-gradient-text font-semibold'>持续更新</span>
      </p>

      <div
        class='flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground'
        style='animation-delay: 300ms;'
      >
        <span class='inline-flex items-center gap-1.5'>
          <span class='relative flex h-2 w-2'>
            <span
              class='absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75'
            ></span>
            <span class='relative inline-flex h-2 w-2 rounded-full bg-emerald-500'></span>
          </span>
          持续更新
        </span>
        <span>·</span>
        <a
          href='https://github.com/nillikechatchat/aoyinai'
          target='_blank'
          rel='noopener'
          class='inline-flex items-center gap-1.5 hover:text-primary'
        >
          <Icon name='github' class='size-4' />
          GitHub
        </a>
        <span>·</span>
        <a href='/rss.xml' class='inline-flex items-center gap-1.5 hover:text-primary'>
          <Icon name='rss' class='size-4' />
          RSS
        </a>
      </div>

      <div class='mt-8 flex flex-wrap justify-center gap-6' style='animation-delay: 400ms;'>
        {
          stats.map((s) => (
            <div class='flex flex-col items-center'>
              <div class='ai-gradient-text text-2xl font-bold'>{s.value}</div>
              <div class='text-xs text-muted-foreground'>{s.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* ==================== 主题分类 ==================== */}
    <section class='animate-ai w-full max-w-5xl px-4 pb-12' style='animation-delay: 500ms;'>
      <h2 class='ai-section-title'>主题分类</h2>
      <div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
        {
          categoryCards.map((c) => (
            <a
              href={`/categories/${c.slug}`}
              class='ai-category-card'
              style={`--card-color: ${c.color};`}
            >
              <span class='ai-card-arrow' aria-hidden='true'>
                →
              </span>
              <span class='flex items-center gap-2'>
                <span class='text-xl'>{c.emoji}</span>
                <span class='ai-card-name'>{c.name}</span>
              </span>
              <span class='ai-card-desc'>{c.desc}</span>
            </a>
          ))
        }
      </div>
    </section>

    {/* ==================== 最新文章 ==================== */}
    {
      allPostsByDate.length > 0 && (
        <section
          class='animate-ai w-full max-w-5xl px-4 pb-12'
          style='animation-delay: 600ms;'
        >
          <div class='mb-6 flex items-end justify-between'>
            <h2 class='ai-section-title mb-0'>最新文章</h2>
            <a href='/blog' class='text-sm text-muted-foreground hover:text-primary'>
              查看全部 →
            </a>
          </div>
          <ul class='flex flex-col gap-2'>
            {allPostsByDate.map((p) => (
              <li>
                <PostPreview post={p} />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <Quote class='mt-4' />
  </main>
</PageLayout>
